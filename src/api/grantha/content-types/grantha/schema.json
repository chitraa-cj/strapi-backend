{
  "kind": "collectionType",
  "collectionName": "granthas",
  "info": {
    "singularName": "grantha",
    "pluralName": "granthas",
    "displayName": "Grantha",
    "description": "Top-level container for a Grantha"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "GranthaName": {
      "type": "string",
      "required": true
    },
    "GranthaType": {
      "type": "enumeration",
      "enum": [
        "Upanishad",
        "Bhagavad Gita",
        "Brahma Sutra",
        "Prakarana Grantha",
        "Bhakthi Grantha"
      ]
    },
    "BhashyamName": {
      "type": "string"
    },
    "BhashyamAuthor": {
      "type": "enumeration",
      "enum": [
        "Sri Shankarayacharya",
        "Upanishad Brahmendra"
      ]
    },
    "IntroductionToTextEnglish": {
      "type": "blocks"
    },
    "BhashyakaraIntroduction": {
      "type": "component",
      "component": "shared.text-and-translation",
      "repeatable": false
    },
    "sections": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::section.section",
      "mappedBy": "grantha"
    },
    "NumberOfTeekas": {
      "type": "integer",
      "required": true
    },
    "teekas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::teeka.teeka",
      "mappedBy": "grantha"
    }
  }
}
